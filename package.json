{
  "name": "foleyard",
  "version": "0.1.7",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/yard-tools/*"
  ],
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "node scripts/verify-workspace-root.cjs",
    "dev": "next dev",
    "dev:desktop": "node scripts/dev-desktop.cjs",
    "bench:scan": "tsx scripts/benchmark-scan.ts",
    "prebuild": "node scripts/verify-workspace-root.cjs",
    "build": "next build",
    "start": "next start",
    "build:desktop": "node scripts/clean-binary.cjs && node node_modules/@electron/rebuild/lib/cli.js -m . -o better-sqlite3 --force && next build && node scripts/rebuild-traced.cjs && electron-builder --config.extraMetadata.foleyardOpenDevTools=true --config.extraMetadata.foleyardResetDatabaseOnBuild=true && node scripts/postinstall.cjs",
    "release": "node scripts/clean-binary.cjs && node node_modules/@electron/rebuild/lib/cli.js -m . -o better-sqlite3 --force && next build && node scripts/rebuild-traced.cjs && electron-builder --publish always && node scripts/postinstall.cjs",
    "release:build": "node scripts/clean-binary.cjs && node node_modules/@electron/rebuild/lib/cli.js -m . -o better-sqlite3 --force && next build && node scripts/rebuild-traced.cjs && electron-builder --publish never && node scripts/postinstall.cjs",
    "release:prepare": "node scripts/prepare-release.cjs",
    "postinstall": "node scripts/postinstall.cjs",
    "lint": "eslint",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.11.0",
    "music-metadata": "^11.12.3",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "picocolors": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "electron",
    "sharp",
    "unrs-resolver"
  ]
}
